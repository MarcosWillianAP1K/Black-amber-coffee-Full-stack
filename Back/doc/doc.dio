<mxfile host="65bd71144e">
    <diagram id="09sXDH3vQAk1PJhfqiXk" name="Page-1">
        <mxGraphModel dx="-2440" dy="795" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml diagrama_classes_revisado\nskinparam classAttributeIconSize 0\nskinparam linetype ortho\n\n&#39; ─────────────────────────────────────────\n&#39;  CLASSES DE USUÁRIO\n&#39; ─────────────────────────────────────────\nabstract class Usuario {\n  - id: String\n  - nomeCompleto: String\n  - email: String\n  - telefone: String\n  - senhaHash: String\n  - perfil: PerfilUsuario\n  - status: StatusUsuario\n  + autenticar(email: String, senha: String): Boolean\n}\n\nclass Cliente extends Usuario {\n  + consultarCardapio(): List&lt;Produto&gt;\n  + verHistorico(): List&lt;Pedido&gt;\n  + finalizarPedido(carrinho: Carrinho, forma: FormaPagamento): Pedido\n}\n\nclass Administrador extends Usuario {\n  + cadastrarColaborador(colaborador: Colaborador): void\n  + gerenciarCardapio(produto: Produto, acao: String): void\n  + emitirRelatorio(filtro: FiltroRelatorio): Relatorio\n  + bloquearUsuario(usuario: Usuario): void\n  + excluirUsuario(usuario: Usuario): void\n  + registrarPonto(colaborador: Colaborador, tipo: TipoPonto): RegistroPonto\n}\n\nclass Colaborador extends Usuario {\n  - cpf: String\n  - cargo: String\n  + visualizarFilaPedidos(): List&lt;Pedido&gt;\n  + atualizarStatusPedido(pedido: Pedido, novoStatus: StatusPedido): void\n}\n\n&#39; ─────────────────────────────────────────\n&#39;  CARDÁPIO\n&#39; ─────────────────────────────────────────\nclass Produto {\n  - id: String\n  - nome: String\n  - descricao: String\n  - preco: Double\n  - categoria: String\n  - imagem: String\n  - disponivel: Boolean\n  + Editar() : void\n}\n\n\nclass Cardapio{\n  - opções : dic[Produto : int]\n  + excluirOpção() : void\n  + adicionarOpção(produto: Produto, disponive : boolean) : boolean\n  + editarOpção() : boolean\n}\n\n\n&#39; ─────────────────────────────────────────\n&#39;  CARRINHO E PEDIDO\n&#39; ─────────────────────────────────────────\nclass Carrinho {\n  - itens : list[Item]\n  + adicionarItem(produto: Produto, quantidade: Integer): void\n  + removerItem(produto: Produto): void\n  + editarObservacao(item: ItemPedido, observacao: String): void\n  + calcularTotal(): Double\n  + estaVazio(): Boolean\n  + esvaziar(): void\n}\n\nclass Item {\n  - id: String\n  - produto : Produto\n  - quantidade: Integer\n  - observacoes: String\n  + calcularSubtotal(): Double\n}\n\nclass Pedido {\n  - id: String\n  - dataHora: DateTime\n  - status: StatusPedido\n  - valorTotal: Double\n  - formaPagamento: FormaPagamento\n  - tempoEspera: Integer\n  - itens : Carrinho\n  + calcularTempoEspera(): Integer\n}\n\n&#39; ─────────────────────────────────────────\n&#39;  RELATÓRIO E PONTO\n&#39; ─────────────────────────────────────────\nclass Relatorio {\n  - id: String\n  - periodo: String\n  - dataGeracao: DateTime\n  - valorTotalVendas: Double\n  - quantidadePedidos: Integer\n}\n\nclass RegistroPonto {\n  - id: String\n  - data: Date\n  - tipo: TipoPonto\n  - hora: DateTime\n}\n\n&#39; ─────────────────────────────────────────\n&#39;  ENUMERAÇÕES\n&#39; ─────────────────────────────────────────\nenum PerfilUsuario {\n  CLIENTE\n  ADMINISTRADOR\n  COLABORADOR\n}\n\nenum StatusUsuario {\n  ATIVO\n  BLOQUEADO\n}\n\nenum StatusPedido {\n  CRIADO\n  EM_PREPARO\n  PRONTO\n  FINALIZADO\n  CANCELADO\n}\n\nenum FormaPagamento {\n  PIX\n  CARTAO_CREDITO\n}\n\nenum TipoPonto {\n  PRESENCA\n  FALTA\n}\n\n&#39; ─────────────────────────────────────────\n&#39;  RELACIONAMENTOS\n&#39; ─────────────────────────────────────────\n\n&#39; Herança\nUsuario &lt;|-- Cliente\nUsuario &lt;|-- Administrador\nUsuario &lt;|-- Colaborador\n\n&#39; Carrinho é exclusivo do Cliente (composição)\nCliente \&quot;1\&quot; *-- \&quot;1\&quot; Carrinho : possui &gt;\n\n&#39; Carrinho contém itens (composição)\nCarrinho \&quot;1\&quot; o-- \&quot;1..*\&quot; Item : contém &gt;\n\n&#39; Pedido contem o carrinho que esta sendo processado (composição)\nPedido \&quot;0..1\&quot; o-- \&quot;1\&quot; Carrinho : contém &gt;\n\n&#39; Pedido é gerado a partir do carrinho e pertence ao cliente\nCliente \&quot;1\&quot; -- \&quot;0..*\&quot; Pedido : realiza &gt;\n\n&#39; Cliente visualiza cardapio\nCliente \&quot;0..*\&quot; -- \&quot;0..1\&quot; Cardapio : visualiza &gt;\n\n&#39; Item referencia produto\nItem \&quot;0..*\&quot; o-- \&quot;1\&quot; Produto : refere-se a &gt;\n\n&#39; Colaborador gerencia pedidos\nColaborador \&quot;1..*\&quot; -- \&quot;0..*\&quot; Pedido : gerencia &gt;\n\n&#39; Admin gera relatório\nAdministrador \&quot;1\&quot; -- \&quot;0..*\&quot; Relatorio : emite &gt;\n\n&#39; Admin registra ponto de colaboradores\nAdministrador \&quot;1\&quot; -- \&quot;0..*\&quot; RegistroPonto : registra &gt;\n\n&#39; Admin gerencia produtos\nAdministrador \&quot;1..*\&quot; -- \&quot;0..*\&quot; Cardapio : gerencia\n\n&#39; Registro de ponto é de um colaborador\nRegistroPonto \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Colaborador : pertence a &gt;\n\n&#39; Produto esta dentro de cardapio\nCardapio \&quot;0..*\&quot; o-- \&quot;0..1\&quot; Produto : esta contido\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1" parent="1">
                        <mxGeometry x="3670" y="470" width="1604" height="1582" as="geometry"/>
                    </mxCell>
                </UserObject>
            </root>
        </mxGraphModel>
    </diagram>
