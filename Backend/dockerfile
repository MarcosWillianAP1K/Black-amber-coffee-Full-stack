# DockerFile for Black Amber Coffee API
# Multi-stage build to optimize the final image size.
# Stage 1 (builder): Install deps + compile TypeScript + resolve path aliases.
# Stage 2 (runtime): Copy compiled JS + production deps only.

# ── Stage 1: Build ──────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

# ── Stage 2: Runtime ────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app

# curl is needed for the HEALTHCHECK
RUN apk add --no-cache curl

# Copy compiled output + production deps
COPY --from=builder /app/dist ./dist
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Default env vars (can be overridden by docker-compose / env_file)
ENV NODE_ENV=production
ENV PORT=3000

# Expose the port the app listens on
EXPOSE ${PORT}

# Health check uses the same PORT the app is bound to
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD curl --fail http://localhost:${PORT}/v1/api/health || exit 1

CMD ["node", "dist/server.js"]