{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "jest"],
    "skipLibCheck": true
  },
  "include": ["src"]
}