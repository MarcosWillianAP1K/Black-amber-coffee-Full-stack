# ──────────────────────────────────────────────
# Black & Amber Coffee — Environment Variables
# ──────────────────────────────────────────────

# Backend API
# Currently hardcoded in packages/utils/core/APIroutes.ts
VITE_API_BASE_URL=http://localhost:3001/v1/api

# Supabase (if using Supabase for auth/storage)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server port for admin app (default: 5173)
# VITE_ADMIN_PORT=5173

# Server port for client app (default: 5174)
# VITE_CLIENT_PORT=5174
